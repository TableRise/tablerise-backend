{
    "compilerOptions": {
        "outDir": "./build",
        "rootDir": ".",
        "target": "es2019",
        "module": "commonjs",
        "typeRoots": ["./node_modules/@types", "src/types/configs", "src/**/*.d.ts"],
        "types": ["mocha"],
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": "./",
        "paths": {
            "src/*": ["src/*"],
            "tests/*": ["tests/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "ts-node": {
        "swc": true
    },
    "exclude": [
        "node_modules",
        "coverage",
        "tests",
        "tests/unit/core/dungeons&dragons5e",
        "tests/unit/interface/dungeons&dragons5e",
        "tests/integration/dungeons&dragons5e"
    ]
}
