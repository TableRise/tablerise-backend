{
    "compilerOptions": {
        "outDir": "./build",
        "rootDir": ".",
        "target": "es2019",
        "module": "commonjs",
        "typeRoots": ["./node_modules/@types", "src/types/configs", "src/**/*.d.ts"],
        "types": ["mocha"],
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "src/*": ["./src/*"],
            "tests/*": ["./tests/*"]
        }
    },
    "ts-node": {
        "swc": true
    },
    "exclude": ["node_modules", "coverage"]
}
